# ── LLM ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
DEV_MODEL=qwen/qwen3-next-80b-a3b-instruct
EVAL_MODEL=anthropic/claude-sonnet-4-6
TEMPERATURE=0.7

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Tenacious Outreach <outreach@yourdomain.com>
# Signing secret from the Resend dashboard → Webhooks → your endpoint → Signing Secret
RESEND_WEBHOOK_SECRET=whsec_...
# Kill-switch: set to "true" only after executive approval
OUTBOUND_LIVE=false
STAFF_SINK_EMAIL=sink@tenacious-pilot.dev

# ── SMS (Africa's Talking) ────────────────────────────────────────────────────
AFRICA_TALKING_USERNAME=sandbox
AFRICA_TALKING_API_KEY=...
AFRICA_TALKING_SENDER_ID=Sandbox

# ── CRM (HubSpot) ─────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=pat-na1-...

# ── Booking (Cal.com) ────────────────────────────────────────────────────────
CALCOM_API_URL=https://api.cal.com
CALCOM_API_KEY=cal_live_...
CALCOM_EVENT_TYPE_SLUG=discovery-call
# Business hours for slot filtering (24h UTC, inclusive start / exclusive end)
BIZ_HOUR_START=9
BIZ_HOUR_END=17

# ── Observability (Langfuse) ─────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite file in project root. For production use Postgres:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./leads.db

# ── Cost guards ───────────────────────────────────────────────────────────────
MAX_COST_PER_LEAD=5.0
DAILY_VOICE_BUDGET=3.0
